{
  "name": "@beam-protocol/directory",
  "version": "1.6.0",
  "description": "Beam Protocol Directory Server — agent registration, discovery, and intent routing",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
