{
  "name": "@beam-protocol/message-bus",
  "version": "1.6.0",
  "description": "Persistent message bus for Beam Protocol — reliable agent-to-agent communication with retry, audit trail, and guaranteed delivery",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "keywords": [
    "beam",
    "beam-protocol",
    "message-bus",
    "agent-communication",
    "ai-agents",
    "message-queue",
    "retry",
    "audit-trail"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Beam-directory/beam-protocol.git",
    "directory": "packages/message-bus"
  },
  "homepage": "https://beam.directory",
  "bugs": {
    "url": "https://github.com/Beam-directory/beam-protocol/issues"
  },
  "bin": {
    "beam-bus": "dist/server.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
