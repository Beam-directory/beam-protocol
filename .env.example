# Beam Directory server
PORT=3100
DB_PATH=/data/beam-directory.db

# Public URLs
PUBLIC_BASE_URL=http://localhost:3100
BEAM_DIRECTORY_BASE_URL=https://beam.directory
BEAM_DIRECTORY_URL=http://localhost:3100

# Admin and rate limiting
BEAM_ADMIN_KEY=change-me
BEAM_RATE_LIMIT_PER_MIN=120

# Federation
BEAM_FEDERATION_SHARED_SECRET=
BEAM_PRIVATE_DIRECTORY_MODE=false

# DID / signing
BEAM_DIRECTORY_DID=did:web:beam.directory
BEAM_DIRECTORY_SIGNING_PRIVATE_KEY=
BEAM_DIRECTORY_SIGNING_PUBLIC_KEY=

# Email verification delivery
# SMTP_HOST takes precedence; if unset and RESEND_API_KEY is set, Resend API is used.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
RESEND_API_KEY=
